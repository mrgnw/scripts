#!/usr/bin/env zsh
# brew install libavif
set -euo pipefail
setopt nocaseglob

trash=false
positional=()
for arg in "$@"; do
	case $arg in
		-t|--trash) trash=true ;;
		*) positional+=("$arg") ;;
	esac
done

if [[ ${#positional[@]} -gt 0 ]]; then
	files=("${positional[@]}")
else
	extensions=(${(f)"$(globs images -x avif)"})
	files=()
	for ext in "${extensions[@]}"; do
		files+=(${~ext}(N))
	done
fi
if [[ ${#files[@]} -eq 0 ]]; then
	echo "No image files found." >&2
	echo "Usage: avifs [-t|--trash] [file ...]" >&2
	exit 1
fi

orig_size=0
for f in "${files[@]}"; do
	orig_size=$(( orig_size + $(stat -f%z "$f") ))
done

raw_exts=(${(f)"$(globs raw)"})
raw_exts=(${raw_exts/\*./})

raw_files=()
normal_files=()
for f in "${files[@]}"; do
	ext="${f##*.}"
	if (( ${raw_exts[(Ie)${ext:l}]} )); then
		raw_files+=("$f")
	else
		normal_files+=("$f")
	fi
done

if [[ ${#raw_files[@]} -gt 0 ]]; then
	img2avif --quality 60 --speed 6 "${raw_files[@]}"
fi

if [[ ${#normal_files[@]} -gt 0 ]]; then
	printf '%s\0' "${normal_files[@]}" | parallel -0 'avifenc -j 1 --speed 6 {} {.}.avif'
fi

avif_size=0
converted=0
for f in "${files[@]}"; do
	avif="${f%.*}.avif"
	if [[ -f "$avif" ]]; then
		avif_size=$(( avif_size + $(stat -f%z "$avif") ))
		converted=$(( converted + 1 ))
	fi
done
saved=$(( orig_size - avif_size ))
if (( orig_size > 0 )); then
	pct=$(( saved * 100 / orig_size ))
	if (( orig_size > 1048576 )); then
		printf '%d files: %.1fMB → %.1fMB (saved %.1fMB, %d%%)\n' \
			$converted $(( orig_size / 1048576.0 )) $(( avif_size / 1048576.0 )) $(( saved / 1048576.0 )) $pct
	else
		printf '%d files: %dKB → %dKB (saved %dKB, %d%%)\n' \
			$converted $(( orig_size / 1024 )) $(( avif_size / 1024 )) $(( saved / 1024 )) $pct
	fi
fi

if $trash; then
	for f in "${files[@]}"; do
		base="${f%.*}"
		if [[ -f "${base}.avif" ]]; then
			mv "$f" ~/.Trash/
		else
			echo "Skipping trash for $f (no .avif output found)" >&2
		fi
	done
fi
